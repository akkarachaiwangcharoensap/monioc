# Monioc — open-source desktop app environment variables
#
# Copy this file to .env and fill in any values you want to override.
# None of these are required for a standard development build.

# Build-time version string. Tauri injects this automatically during tauri build.
# VITE_APP_VERSION=1.0.0

# App homepage URL (used in the About section).
# VITE_APP_URL=https://github.com/your-org/monioc

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Monioc",
  "version": "0.1.0",
  "identifier": "com.monioc-app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run vite:dev --prefix ../",
    "beforeBuildCommand": "npm run vite:build --prefix ../"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "",
        "width": 1280,
        "height": 860,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: https://fonts.gstatic.com; connect-src ipc: http://ipc.localhost tauri: asset: http://localhost:* https:; img-src 'self' asset: tauri: blob: data: http: https:; style-src 'unsafe-inline' 'self' tauri: asset: https://cdn.jsdelivr.net; script-src 'self' 'unsafe-eval' https://cdn.jsdelivr.net; font-src 'self' data: asset: https://fonts.gstatic.com; frame-src http://localhost:* https:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "process_statscan_to_sqlite.py": "process_statscan_to_sqlite.py",
      "../build/grocery.sqlite3": "grocery.sqlite3",
      "scan_receipt.py": "scan_receipt.py",
      "categorize_items.py": "categorize_items.py",
      "check_models.py": "check_models.py"
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:receipts.sqlite3"]
    }
  }
}

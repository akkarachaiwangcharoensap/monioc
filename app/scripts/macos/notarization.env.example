# Copy to a local env file and source it before running the notarized build.
# Example: cp scripts/macos/notarization.env.example scripts/macos/notarization.env
#          source scripts/macos/notarization.env

# Developer ID Application certificate common name from Keychain Access.
# Example: Developer ID Application: Your Name (TEAMID1234)
export APPLE_SIGNING_IDENTITY="Developer ID Application: YOUR_NAME (TEAMID1234)"

# Apple account used for notarization.
export APPLE_ID="akkarachaiwangcharoensap@hotmail.com"

# App-specific password generated at appleid.apple.com.
export APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Apple Developer Team ID.
export APPLE_TEAM_ID="3H78C4KJWP"

{
  "name": "monioc",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "landing"
  ],
  "scripts": {
    "dev": "cd app && python3 scripts/build-grocery-db.py && tauri dev",
    "build": "cd app && python3 scripts/setup-python-deps.py && python3 scripts/build-grocery-db.py --force && tauri build",
    "build:app": "cd app && python3 scripts/setup-python-deps.py && tauri build --bundles app",
    "preview": "vite --config app/vite.config.ts",
    "vite:dev": "vite --config app/vite.config.ts",
    "vite:build": "python3 app/scripts/build-grocery-db.py && tsc -p app/tsconfig.json && vite build --config app/vite.config.ts",
    "landing": "npm run dev --workspace=landing",
    "build:landing": "npm run build --workspace=landing",
    "test": "vitest run --config app/vite.config.ts",
    "test:ui": "vitest --ui --config app/vite.config.ts",
    "test:coverage": "vitest --coverage --config app/vite.config.ts",
    "test:e2e": "playwright test --config app/playwright.config.ts",
    "test:e2e:headed": "playwright test --headed --config app/playwright.config.ts",
    "test:all": "npm run test && npm run test:e2e",
    "lint": "eslint app/src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc -p app/tsconfig.json --noEmit",
    "setup:python-deps": "python3 app/scripts/setup-python-deps.py",
    "build:grocery-db": "python3 app/scripts/build-grocery-db.py",
    "build:grocery-db:force": "python3 app/scripts/build-grocery-db.py --force",
    "ci": "bash scripts/ci.sh",
    "ci:fast": "bash scripts/ci.sh --fast"
  },
  "dependencies": {
    "@monioc/shared": "*",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@wojtekmaj/react-datetimerange-picker": "^7.0.0",
    "nanoid": "^5.1.7",
    "react": "^19.2.4",
    "react-date-picker": "^12.0.1",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "react-select": "^5.10.2",
    "react-sortablejs": "^6.1.4",
    "recharts": "^3.8.0",
    "sortablejs": "^1.15.7",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.17.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^25.0.0",
    "sharp": "^0.32.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
